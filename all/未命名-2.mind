{"root":{"data":{"id":"didxdq4d6c80","created":1778307453528,"text":"内弹道计算方法及理论的局限性"},"children":[{"data":{"id":"didz96i0neg0","created":1778312739581,"text":"零维/经典内弹道模型\n空间均匀分布假设：即假设药室内任意时刻的气体密度、温度、压力以及固体颗粒的分布在空间尺度上不存在梯度"},"children":[{"data":{"id":"didz9gojg800","created":1778312761743,"text":"点传火过程"},"children":[{"data":{"id":"didzcvm4jgw0","created":1778313029342,"text":"忽略点火药的燃烧过程","expandState":"expand"},"children":[{"data":{"id":"didzfgk85nc0","created":1778313231668,"text":"时间上存在误差，无法反映\n点火药建压速率对主装药初始燃烧状态的影响","expandState":"expand"},"children":[{"data":{"id":"didz9m46lmw0","created":1778312773574,"text":"忽略点火药的影响","expandState":"expand"},"children":[]},{"data":{"id":"didz9pm4rrc0","created":1778312781189,"text":"点火药瞬时燃烧假设"},"children":[]}]}]},{"data":{"id":"didzd2ptfig0","created":1778313044802,"text":"考虑点火药的燃烧过程","expandState":"expand"},"children":[{"data":{"id":"didz9qa5dfc0","created":1778312782641,"text":"点火药动态源项假设"},"children":[{"data":{"id":"didzf3c474w0","created":1778313202879,"text":"引入点火药产气率的源项"},"children":[]},{"data":{"id":"didzgf8w9bk0","created":1778313307170,"text":"主装药点火设定宏观标量触发阈值（平均压力或者温度）：\n在达到阈值前，仅点火药源项产气；达到阈值后，主药燃速方程被激活。"},"children":[]}]}]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}